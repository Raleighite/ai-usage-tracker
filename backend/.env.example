# AI Usage Tracker — Backend Environment Variables
# Copy to .env and fill in your values

# Required: Claude OAuth access token
# After running `claude login`, copy accessToken from ~/.claude/.credentials.json
CLAUDE_OAUTH_TOKEN=

# Optional: enable Codex usage endpoint
# Set to the path of your OpenClaw agents directory
# CODEX_TRAJECTORY_DIR=/home/user/.openclaw/agents

# Port (default: 8030 — must match SERVER_PORT in ESP32 firmware config.h)
# PORT=8030
